{
	"info": {
		"name": "Quiza V2 E2E API Tests",
		"description": "Full E2E test collection for Quiza V2 API.\n\nFlow: Health Check -> Dev Login -> Auth Me -> Domains List -> Goal Create -> Get Roadmap -> Sessions Create -> Answers Submit -> Stats -> Logout -> Auth Me (401)\n\nPrerequisite: Run `node e2e/setup-test-data.js` to create roadmap + checkpoint test data.",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{ "key": "baseUrl", "value": "http://localhost:8080" },
		{ "key": "domainId", "value": "" },
		{ "key": "domainName", "value": "" },
		{ "key": "goalId", "value": "" },
		{ "key": "checkpointId", "value": "" },
		{ "key": "sessionId", "value": "" },
		{ "key": "questionId", "value": "" },
		{ "key": "questionAnswer", "value": "" }
	],
	"item": [
		{
			"name": "01. Health Check",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/health",
					"host": ["{{baseUrl}}"],
					"path": ["health"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Health check returns 200 with status ok', function () {",
							"    pm.response.to.have.status(200);",
							"    var json = pm.response.json();",
							"    pm.expect(json.status).to.eql('ok');",
							"});"
						]
					}
				}
			]
		},
		{
			"name": "02. Dev Login",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"world_id\": \"test-user-e2e\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/auth/dev-login",
					"host": ["{{baseUrl}}"],
					"path": ["auth", "dev-login"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Dev login returns 201 with success', function () {",
							"    pm.response.to.have.status(201);",
							"    var json = pm.response.json();",
							"    pm.expect(json.success).to.eql(true);",
							"});",
							"",
							"pm.test('Set-Cookie header contains access_token', function () {",
							"    var setCookie = pm.response.headers.get('Set-Cookie');",
							"    pm.expect(setCookie).to.include('access_token=');",
							"});"
						]
					}
				}
			]
		},
		{
			"name": "03. Auth Me",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/auth/me",
					"host": ["{{baseUrl}}"],
					"path": ["auth", "me"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Auth me returns 200 with user profile', function () {",
							"    pm.response.to.have.status(200);",
							"    var json = pm.response.json();",
							"    pm.expect(json.id).to.be.a('string');",
							"    pm.expect(json.world_id).to.eql('test-user-e2e');",
							"    pm.expect(json).to.have.property('nickname');",
							"    pm.expect(json).to.have.property('created_at');",
							"    pm.expect(json).to.have.property('is_premium');",
							"});"
						]
					}
				}
			]
		},
		{
			"name": "04. Domains List",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/domains",
					"host": ["{{baseUrl}}"],
					"path": ["domains"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Domains list returns 200 with non-empty array', function () {",
							"    pm.response.to.have.status(200);",
							"    var json = pm.response.json();",
							"    pm.expect(json).to.be.an('array').that.is.not.empty;",
							"    // Each domain should have id, name, created_at",
							"    var first = json[0];",
							"    pm.expect(first).to.have.property('id');",
							"    pm.expect(first).to.have.property('name');",
							"    pm.expect(first).to.have.property('created_at');",
							"});",
							"",
							"pm.test('Find 토익 domain and save ID', function () {",
							"    var json = pm.response.json();",
							"    var toeic = json.find(function(d) { return d.name === '토익'; });",
							"    pm.expect(toeic).to.not.be.undefined;",
							"    pm.collectionVariables.set('domainId', toeic.id);",
							"    pm.collectionVariables.set('domainName', toeic.name);",
							"});"
						]
					}
				}
			]
		},
		{
			"name": "05. Domain Tags",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/domains/{{domainId}}/tags",
					"host": ["{{baseUrl}}"],
					"path": ["domains", "{{domainId}}", "tags"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Tags returned for domain', function () {",
							"    pm.response.to.have.status(200);",
							"    var json = pm.response.json();",
							"    pm.expect(json).to.be.an('array').that.is.not.empty;",
							"    var first = json[0];",
							"    pm.expect(first).to.have.property('id');",
							"    pm.expect(first).to.have.property('name');",
							"    pm.expect(first).to.have.property('domain_id');",
							"});"
						]
					}
				}
			]
		},
		{
			"name": "06. Goals List (before create)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/goals",
					"host": ["{{baseUrl}}"],
					"path": ["goals"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Goals list returns 200', function () {",
							"    pm.response.to.have.status(200);",
							"    var json = pm.response.json();",
							"    pm.expect(json).to.be.an('array');",
							"});",
							"",
							"// Find existing 토익 goal with roadmap (created by setup script)",
							"pm.test('Find 토익 goal with roadmap', function () {",
							"    var json = pm.response.json();",
							"    var toeicGoal = json.find(function(g) {",
							"        return g.domain.name === '토익' && g.hasRoadmap === true;",
							"    });",
							"    pm.expect(toeicGoal, '토익 goal with roadmap should exist (run setup script first)').to.not.be.undefined;",
							"    pm.collectionVariables.set('goalId', toeicGoal.id);",
							"});"
						]
					}
				}
			]
		},
		{
			"name": "07. Get Roadmap by goalId",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/roadmaps/{{goalId}}",
					"host": ["{{baseUrl}}"],
					"path": ["roadmaps", "{{goalId}}"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Roadmap returned with checkpoints', function () {",
							"    pm.response.to.have.status(200);",
							"    var json = pm.response.json();",
							"    pm.expect(json).to.not.be.null;",
							"    pm.expect(json.id).to.be.a('string');",
							"    pm.expect(json.title).to.be.a('string');",
							"    pm.expect(json.goal_id).to.eql(pm.collectionVariables.get('goalId'));",
							"    pm.expect(json.checkpoints).to.be.an('array').that.is.not.empty;",
							"});",
							"",
							"pm.test('Save first checkpoint ID', function () {",
							"    var json = pm.response.json();",
							"    var cp = json.checkpoints[0];",
							"    pm.expect(cp).to.have.property('id');",
							"    pm.expect(cp).to.have.property('title');",
							"    pm.expect(cp).to.have.property('tag_id');",
							"    pm.expect(cp).to.have.property('difficulty');",
							"    pm.expect(cp).to.have.property('order');",
							"    pm.expect(cp).to.have.property('status');",
							"    pm.collectionVariables.set('checkpointId', cp.id);",
							"});"
						]
					}
				}
			]
		},
		{
			"name": "08. Sessions Create",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"checkpoint_id\": \"{{checkpointId}}\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/sessions",
					"host": ["{{baseUrl}}"],
					"path": ["sessions"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Session created with questions (201)', function () {",
							"    pm.response.to.have.status(201);",
							"    var json = pm.response.json();",
							"    pm.expect(json.session_id).to.be.a('string');",
							"    pm.expect(json.questions).to.be.an('array').that.is.not.empty;",
							"    pm.collectionVariables.set('sessionId', json.session_id);",
							"});",
							"",
							"pm.test('Questions have correct shape and save first question', function () {",
							"    var json = pm.response.json();",
							"    var q = json.questions[0];",
							"    pm.expect(q).to.have.property('id');",
							"    pm.expect(q).to.have.property('tag');",
							"    pm.expect(q).to.have.property('type');",
							"    pm.expect(q).to.have.property('difficulty');",
							"    pm.expect(q).to.have.property('content');",
							"    pm.expect(q).to.have.property('options');",
							"    pm.collectionVariables.set('questionId', q.id);",
							"    // For multi-choice, pick the first option as answer (may or may not be correct)",
							"    if (q.options && q.options.length > 0) {",
							"        pm.collectionVariables.set('questionAnswer', q.options[0]);",
							"    } else {",
							"        pm.collectionVariables.set('questionAnswer', 'test answer');",
							"    }",
							"});"
						]
					}
				}
			]
		},
		{
			"name": "09. Answers Submit",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"question_id\": \"{{questionId}}\",\n  \"user_answer\": \"{{questionAnswer}}\",\n  \"session_id\": \"{{sessionId}}\"\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/answers",
					"host": ["{{baseUrl}}"],
					"path": ["answers"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Answer graded (201)', function () {",
							"    pm.response.to.have.status(201);",
							"    var json = pm.response.json();",
							"    pm.expect(json).to.have.property('is_correct');",
							"    pm.expect(json.is_correct).to.be.a('boolean');",
							"    pm.expect(json).to.have.property('correct_answer');",
							"    pm.expect(json.correct_answer).to.be.a('string');",
							"    pm.expect(json).to.have.property('explanation');",
							"    pm.expect(json).to.have.property('score');",
							"    pm.expect(json).to.have.property('grade_reason');",
							"});"
						]
					}
				}
			]
		},
		{
			"name": "10. Sessions Complete",
			"request": {
				"method": "POST",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/sessions/{{sessionId}}/complete",
					"host": ["{{baseUrl}}"],
					"path": ["sessions", "{{sessionId}}", "complete"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Session completed (201)', function () {",
							"    pm.response.to.have.status(201);",
							"    var json = pm.response.json();",
							"    pm.expect(json).to.have.property('score');",
							"    pm.expect(json.score).to.be.a('number');",
							"    pm.expect(json).to.have.property('total');",
							"    pm.expect(json.total).to.be.a('number');",
							"    pm.expect(json).to.have.property('correct');",
							"    pm.expect(json.correct).to.be.a('number');",
							"    pm.expect(json).to.have.property('passed');",
							"    pm.expect(json.passed).to.be.a('boolean');",
							"    pm.expect(json).to.have.property('checkpoint_status');",
							"});"
						]
					}
				}
			]
		},
		{
			"name": "11. Stats",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/stats",
					"host": ["{{baseUrl}}"],
					"path": ["stats"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Stats returned (200)', function () {",
							"    pm.response.to.have.status(200);",
							"    var json = pm.response.json();",
							"    pm.expect(json).to.have.property('tag_stats');",
							"    pm.expect(json.tag_stats).to.be.an('array');",
							"    pm.expect(json).to.have.property('total_answered');",
							"    pm.expect(json.total_answered).to.be.a('number');",
							"    pm.expect(json.total_answered).to.be.at.least(1);",
							"    pm.expect(json).to.have.property('roadmap_progress');",
							"    pm.expect(json.roadmap_progress).to.have.property('passed');",
							"    pm.expect(json.roadmap_progress).to.have.property('total');",
							"    pm.expect(json.roadmap_progress).to.have.property('percentage');",
							"});"
						]
					}
				}
			]
		},
		{
			"name": "12. Questions Generate (403 expected)",
			"request": {
				"method": "POST",
				"header": [
					{ "key": "Content-Type", "value": "application/json" }
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"tagId\": \"83145b56-0980-4383-b317-b415abc955f7\",\n  \"difficulty\": 3,\n  \"count\": 5\n}"
				},
				"url": {
					"raw": "{{baseUrl}}/questions/generate",
					"host": ["{{baseUrl}}"],
					"path": ["questions", "generate"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Non-premium user gets 403', function () {",
							"    pm.response.to.have.status(403);",
							"    var json = pm.response.json();",
							"    pm.expect(json.message).to.include('Premium');",
							"});"
						]
					}
				}
			]
		},
		{
			"name": "13. Auth Logout",
			"request": {
				"method": "POST",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/auth/logout",
					"host": ["{{baseUrl}}"],
					"path": ["auth", "logout"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Logout returns 201 with success', function () {",
							"    pm.response.to.have.status(201);",
							"    var json = pm.response.json();",
							"    pm.expect(json.success).to.eql(true);",
							"});",
							"",
							"pm.test('access_token cookie is cleared', function () {",
							"    var setCookie = pm.response.headers.get('Set-Cookie');",
							"    pm.expect(setCookie).to.include('access_token=');",
							"});"
						]
					}
				}
			]
		},
		{
			"name": "14. Auth Me after Logout (401)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{baseUrl}}/auth/me",
					"host": ["{{baseUrl}}"],
					"path": ["auth", "me"]
				}
			},
			"event": [
				{
					"listen": "test",
					"script": {
						"type": "text/javascript",
						"exec": [
							"pm.test('Unauthorized after logout (401)', function () {",
							"    pm.response.to.have.status(401);",
							"});"
						]
					}
				}
			]
		}
	]
}
